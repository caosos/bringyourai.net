# Example nginx configuration for BringYourAI.net with the minimal Aria backend prototype.
#
# Site purpose:
# - Michael Chambers' live resume / AI systems portfolio.
# - Same-origin Aria chat through POST /api/aria-chat.
# - OpenAI credentials stay only in the server-side Node.js environment.
#
# Preferred server root: /srv/www/bringyourai.net
# Copy to: /etc/nginx/sites-available/bringyourai.net
# Assumes the Node process is running on 127.0.0.1:3000.

server {
    listen 80;
    listen [::]:80;

    server_name bringyourai.net www.bringyourai.net;

    access_log /var/log/nginx/bringyourai.net.access.log;
    error_log /var/log/nginx/bringyourai.net.error.log;

    # Proxy the entire site to the minimal Node server so /api/aria-chat
    # and the static portfolio pages remain same-origin.
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Do not serve hidden files such as .git, .env, or editor metadata if
    # this config is later mixed with direct static-file serving.
    location ~ /\. {
        deny all;
    }

    # Keep common private/config file types out of public responses if direct
    # static-file serving is added later.
    location ~* \.(?:env|ini|log|sql|bak|old|orig|swp)$ {
        deny all;
    }
}
